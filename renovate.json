{
    "extends": [
        "config:best-practices",
        ":enablePreCommit",
        "docker:pinDigests"
    ],
    "labels": [
        "renovate"
    ],
    "packageRules": [
        {
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "groupName": "minor and patch",
            "groupSlug": "minor-patch"
        }
    ],
    "prHourlyLimit": 2,
    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/^\\.github/workflows/validate\\.yml$/"
            ],
            "matchStrings": [
                "grafana/(?<depName>[a-zA-Z0-9/_-]+):(?<currentValue>[v0-9][a-zA-Z0-9._-]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
            ],
            "autoReplaceStringTemplate": "grafana/{{{depName}}}:{{{newValue}}}{{#if newDigest}}@{{{newDigest}}}{{/if}}",
            "datasourceTemplate": "docker",
            "depNameTemplate": "grafana/{{{depName}}}"
        }
    ],
    "prConcurrentLimit": 2
}
